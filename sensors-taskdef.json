{
  "family": "smart-outfit-sensor-simulator",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::121332300574:role/LabRole",
  "taskRoleArn": "arn:aws:iam::121332300574:role/LabRole",
  "containerDefinitions": [
    {
      "name": "sensor-simulator",
      "image": "121332300574.dkr.ecr.us-east-1.amazonaws.com/smart-outfit/sensor-simulator:latest",
      "essential": true,
      "environment": [
        { "name": "FOG_URL", "value": "http://smart-outfit-fog-alb-716493326.us-east-1.elb.amazonaws.com" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-region": "us-east-1",
          "awslogs-group": "/ecs/smart-outfit/sensor-simulator",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
