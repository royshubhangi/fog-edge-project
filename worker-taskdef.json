{
    "family": "smart-outfit-worker",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::121332300574:role/LabRole",
    "taskRoleArn": "arn:aws:iam::121332300574:role/LabRole",
    "containerDefinitions": [
      {
        "name": "worker",
        "image": "121332300574.dkr.ecr.us-east-1.amazonaws.com/smart-outfit/cloud-backend:latest",
        "essential": true,
        "command": ["python", "-m", "app.worker"],
        "environment": [
          { "name": "AWS_REGION", "value": "us-east-1" },
          { "name": "SQS_QUEUE_URL", "value": "https://sqs.us-east-1.amazonaws.com/121332300574/outfit-ingest-queue" },
          { "name": "DYNAMODB_TABLE_RECOMMENDATIONS", "value": "outfit-recommendations" },
          { "name": "DYNAMODB_TABLE_SENSORS", "value": "outfit-sensor-snapshots" }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-region": "us-east-1",
            "awslogs-group": "/ecs/smart-outfit/worker",
            "awslogs-stream-prefix": "ecs"
          }
        }
      }
    ]
  }